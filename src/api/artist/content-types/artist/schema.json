{
  "kind": "collectionType",
  "collectionName": "artists",
  "info": {
    "singularName": "artist",
    "pluralName": "artists",
    "displayName": "Artist"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "bio": {
      "type": "richtext"
    },
    "profile_image": {
      "type": "string"
    },
    "cover_image": {
      "type": "string"
    },
    "medium": {
      "type": "string"
    },
    "isPublished": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "rating": {
      "type": "decimal",
      "default": 0,
      "min": 0,
      "max": 5
    },
    "city": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::city.city",
      "inversedBy": "artists"
    },
    "artworks": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::artwork.artwork",
      "mappedBy": "artist"
    },
    "artist_quiz": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::artist-quiz.artist-quiz",
      "mappedBy": "artist"
    },
    "user_discounts": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::user-discount.user-discount",
      "mappedBy": "artist"
    },
    "artist_events": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::artist-event.artist-event",
      "mappedBy": "artists"
    }
  }
}
