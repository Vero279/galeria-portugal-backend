{
  "kind": "collectionType",
  "collectionName": "artworks",
  "info": {
    "singularName": "artwork",
    "pluralName": "artworks",
    "displayName": "Artwork"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "image_url": {
      "type": "string",
      "required": true
    },
    "year": {
      "type": "integer",
      "min": 1971,
      "max": 2100
    },
    "medium": {
      "type": "string"
    },
    "dimensions": {
      "type": "string"
    },
    "price": {
      "type": "decimal"
    },
    "description": {
      "type": "blocks"
    },
    "artist": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::artist.artist",
      "inversedBy": "artworks"
    },
    "artwork_reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::artwork-review.artwork-review",
      "mappedBy": "artwork"
    },
    "wall_uploads": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::wall-upload.wall-upload",
      "mappedBy": "artwork"
    },
    "cart_items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::cart-item.cart-item",
      "mappedBy": "artwork"
    },
    "isPublished": {
      "type": "boolean",
      "default": false
    }
  }
}
